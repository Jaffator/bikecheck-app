            "type": "number",
            "example": 1
          },
          "avatar_url": {
            "type": "string",
            "example": "https://example.com/avatar.jpg"
          }
        },
        "required": [
          "name",
          "language",
          "currency",
          "weight_kg",
          "ride_style_id",
          "avatar_url"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateBikeWithComponentsDto": {
        "type": "object",
        "properties": {}
      },
      "ResponseBikeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "user_id": {
            "type": "number",
            "example": 15
          },
          "organization_id": {
            "type": "object",
            "example": 10,
            "nullable": true
          },
          "bike_brand": {
            "type": "string",
            "example": "Specialized",
            "nullable": true
          },
          "bike_model": {
            "type": "object",
            "example": "Stumpjumper",
            "nullable": true
          },
          "image_url": {
            "type": "object",
            "example": "https://example.com/bike-image.jpg",
            "nullable": true
          },
          "bike_type_id": {
            "type": "object",
            "example": 1,
            "nullable": true
          },
          "bikename": {
            "type": "object",
            "example": "Tarmac SL7",
            "nullable": true
          },
          "year": {
            "type": "object",
            "example": 2024,
            "nullable": true
          },
          "description": {
            "type": "object",
            "example": "Serviced bike, top health",
            "nullable": true
          },
          "wheel_size_id": {
            "type": "object",
            "example": 2,
            "nullable": true
          },
          "bike_size_id": {
            "type": "object",
            "example": 3,
            "nullable": true
          },
          "mileage_km": {
            "type": "object",
            "example": 1540,
            "nullable": true
          },
          "created_at": {
            "type": "object",
            "example": "2024-01-01T12:00:00.000Z",
            "nullable": true
          },
          "updated_at": {
            "type": "object",
            "example": "2024-01-02T12:00:00.000Z",
            "nullable": true
          },
          "frame_material": {
            "type": "object",
            "example": "Carbon",
            "nullable": true
          },
          "is_deleted": {
            "type": "object",
            "example": false,
            "nullable": true
          },
          "deleted_at": {
            "type": "object",
            "example": null,
            "nullable": true
          }
        },
        "required": [
          "id",
          "user_id",
          "organization_id",
          "bike_brand",
          "bike_model",
          "image_url",
          "bike_type_id",
          "bikename",
          "year",
          "description",
          "wheel_size_id",
          "bike_size_id",
          "mileage_km",
          "created_at",
          "updated_at",
          "frame_material",
          "is_deleted",
          "deleted_at"
        ]
      },
      "UpdateBikeDto": {
        "type": "object",
        "properties": {}
      }
