    "schemas": {
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string"
          },
          "avatar_url": {
            "type": "object",
            "example": "https://example.com/avatar.jpg",
            "nullable": true
          },
          "language": {
            "type": "object",
            "example": "en",
            "nullable": true
          },
          "currency": {
            "type": "object",
            "example": "czk",
            "nullable": true
          },
          "weight_kg": {
            "type": "object",
            "example": 70,
            "nullable": true
          },
          "ride_style_id": {
            "type": "object",
            "example": 1,
            "nullable": true
          },
          "is_active": {
            "type": "boolean",
            "example": true
          },
          "last_login_at": {
            "type": "object",
            "example": "2024-01-01T12:00:00Z"
          },
          "created_at": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T12:00:00Z"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-02T12:00:00Z"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "avatar_url",
          "language",
          "currency",
          "weight_kg",
          "ride_style_id",
          "is_active",
          "last_login_at",
          "created_at",
          "updated_at"
        ]
      },
