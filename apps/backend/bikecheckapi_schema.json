  "info": {
    "title": "BikeCheck API",
    "description": "Bikechek API documentation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string"
          },
          "avatar_url": {
            "type": "object",
            "example": "https://example.com/avatar.jpg",
            "nullable": true
          },
          "language": {
            "type": "object",
            "example": "en",
            "nullable": true
          },
          "currency": {
            "type": "object",
            "example": "czk",
            "nullable": true
          },
          "weight_kg": {
            "type": "object",
            "example": 70,
            "nullable": true
          },
          "is_active": {
            "type": "boolean",
            "example": true
          },
          "last_login_at": {
            "type": "object",
            "example": "2024-01-01T12:00:00Z"
          },
          "created_at": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T12:00:00Z"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-02T12:00:00Z"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "avatar_url",
          "language",
          "currency",
          "weight_kg",
          "is_active",
          "last_login_at",
          "created_at",
          "updated_at"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123"
          },
          "language": {
            "type": "string",
            "example": "en"
          }
        },
        "required": [
          "name",
          "email",
          "password",
          "language"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "language": {
            "type": "string",
            "example": "en"
          },
          "currency": {
            "type": "string",
            "example": "czk"
          },
          "weight_kg": {
            "type": "number",
            "example": 70
          },
          "ride_style_id": {
            "type": "number",
            "example": 1
          },
          "avatar_url": {
            "type": "string",
            "example": "https://example.com/avatar.jpg"
          }
        },
        "required": [
          "name",
          "language",
          "currency",
          "weight_kg",
          "ride_style_id",
          "avatar_url"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateBikeDto": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "number",
            "example": 1
          },
          "bike_brand": {
            "type": "string",
            "example": "Trek"
          },
          "bike_model": {
            "type": "string",
            "example": "Domane SL7"
          },
          "organization_id": {
            "type": "number",
            "example": 1
          },
          "bikename": {
            "type": "string",
            "example": "Tarmac SL7"
          },
          "year": {
            "type": "number",
            "example": 2024
          },
          "description": {
            "type": "string",
            "example": "Serviced bike, top health"
          },
          "wheel_size_id": {
            "type": "number",
            "example": 2
          },
          "bike_size_id": {
            "type": "number",
            "example": 3
          },
          "bike_type_id": {
            "type": "number",
            "example": 1
          },
          "mileage_km": {
            "type": "number",
            "example": 1540
          },
          "frame_material": {
            "type": "string",
            "example": "Carbon"
          },
          "image_url": {
            "type": "string",
            "example": "https://example.com/bike-image.jpg"
          }
        },
        "required": [
          "user_id",
          "bike_brand"
        ]
      },
      "CreateComponentsDto": {
        "type": "object",
        "properties": {
          "bike_id": {
            "type": "number",
            "example": 1
          },
          "component_type_id": {
            "type": "number",
            "example": 12
          },
          "component_desc": {
            "type": "string",
            "example": "Fox 38 Factory Grip2",
            "nullable": true
          },
          "mounted_at": {
            "format": "date-time",
            "type": "string",
            "example": "2026-03-26T10:00:00.000Z",
            "nullable": true
          },
          "total_mileage_km": {
            "type": "number",
            "example": 1200,
            "nullable": true
          },
          "is_active": {
            "type": "boolean",
            "example": true,
            "nullable": true
          },
          "note": {
            "type": "string",
            "example": "Mounted after spring service",
            "nullable": true
          },
          "interval_id": {
            "type": "number",
            "example": 2,
            "nullable": true
          },
          "brake_load_since_service": {
            "type": "number",
            "example": 350,
            "nullable": true
          },
          "last_serviced_at": {
            "format": "date-time",
            "type": "string",
            "example": "2026-03-20T10:00:00.000Z",
            "nullable": true
          }
        },
        "required": [
          "bike_id",
          "component_type_id"
        ]
      },
      "CreateBikeWithComponentsDto": {
        "type": "object",
        "properties": {
          "bike": {
            "$ref": "#/components/schemas/CreateBikeDto"
          },
          "components": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateComponentsDto"
            }
          }
        },
        "required": [
          "bike",
          "components"
        ]
      },
      "ResponseBikeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "user_id": {
            "type": "number",
            "example": 15
          },
          "organization_id": {
            "type": "object",
            "example": 10,
            "nullable": true
          },
          "ride_style_id": {
            "type": "object",
            "example": "Trail",
            "nullable": true
          },
          "bike_brand": {
            "type": "string",
            "example": "Specialized",
            "nullable": true
          },
          "bike_model": {
            "type": "object",
            "example": "Stumpjumper",
            "nullable": true
          },
          "image_url": {
            "type": "object",
            "example": "https://example.com/bike-image.jpg",
            "nullable": true
          },
          "bike_type_id": {
            "type": "object",
            "example": 1,
            "nullable": true
          },
          "bikename": {
            "type": "object",
            "example": "Tarmac SL7",
            "nullable": true
          },
          "year": {
            "type": "object",
            "example": 2024,
            "nullable": true
          },
          "description": {
            "type": "object",
            "example": "Serviced bike, top health",
            "nullable": true
          },
          "wheel_size_id": {
            "type": "object",
            "example": 2,
            "nullable": true
          },
          "bike_size_id": {
            "type": "object",
            "example": 3,
            "nullable": true
          },
          "mileage_km": {
            "type": "object",
            "example": 1540,
            "nullable": true
          },
          "created_at": {
            "type": "object",
            "example": "2024-01-01T12:00:00.000Z",
            "nullable": true
          },
          "updated_at": {
            "type": "object",
            "example": "2024-01-02T12:00:00.000Z",
            "nullable": true
          },
          "frame_material": {
            "type": "object",
            "example": "Carbon",
            "nullable": true
          },
          "is_deleted": {
            "type": "object",
            "example": false,
            "nullable": true
          },
          "deleted_at": {
            "type": "object",
            "example": null,
            "nullable": true
          }
        },
        "required": [
          "id",
          "user_id",
          "organization_id",
          "ride_style_id",
          "bike_brand",
          "bike_model",
          "image_url",
          "bike_type_id",
          "bikename",
