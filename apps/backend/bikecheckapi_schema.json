        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123"
          },
          "language": {
            "type": "string",
            "example": "en"
          }
        },
        "required": [
          "name",
          "email",
          "password",
          "language"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "language": {
            "type": "string",
            "example": "en"
          },
          "currency": {
            "type": "string",
            "example": "czk"
          },
          "weight_kg": {
            "type": "number",
            "example": 70
          },
